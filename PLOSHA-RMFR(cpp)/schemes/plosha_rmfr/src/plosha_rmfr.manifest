[libos]
entrypoint = "plosha_rmfr"

[loader]
log_level = "error"
insecure__use_cmdline_argv = true

[loader.env]
LD_LIBRARY_PATH = "/lib:/lib/x86_64-linux-gnu:/usr/lib/x86_64-linux-gnu"

[loader.entrypoint]
uri = "file:/usr/lib/x86_64-linux-gnu/gramine/libsysdb.so"
sha256 = "e6014513d79ba404b73fcb310c619ddba07da66e696398829cd4a9eb3553c6a5"

[sys]
enable_sigterm_injection = true

[sgx]
enclave_size = "512M"
max_threads = 16
allowed_files = [
    "file:/run/media/peppo/DATA1/PLOSHA/PLOSHA-RMFR(cpp)/dataset/",
    "file:/run/media/peppo/DATA1/PLOSHA/PLOSHA-RMFR(cpp)/schemes/plosha_rmfr/",
]
isvprodid = 0
isvsvn = 0
remote_attestation = "none"
debug = false
enable_stats = false
edmm_enable = false
use_exinfo = false

[sgx.cpu_features]
avx = "unspecified"
avx2 = "unspecified"
rdrand = "unspecified"
aesni = "unspecified"
avx512 = "unspecified"
amx = "unspecified"
mpx = "disabled"
pkru = "disabled"

